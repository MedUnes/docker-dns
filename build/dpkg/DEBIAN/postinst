#!/bin/bash
# postinst for docker-dns

PATH=$PATH:/bin:/usr/bin:/sbin:/usr/sbin
SERVICE_NAME=docker-dns
CONFIG_FILE="/etc/docker-dns/docker-dns.conf"

get_custom_ip() {
    if [ -f "$CONFIG_FILE" ]; then
        custom_ip=$(grep '^IP=' "$CONFIG_FILE" | head -n1 | cut -d'=' -f2)
        echo "$custom_ip"
    else
        echo ""
    fi
}

get_custom_tld() {
    if [ -f "$CONFIG_FILE" ]; then
        custom_tld=$(grep '^TLD=' "$CONFIG_FILE" | head -n1 | cut -d'=' -f2)
        echo "$custom_tld"
    else
        echo ""
    fi
}

case $1 in
configure)
    if [ ! -d /run/systemd/system ]; then
        echo "Failed to detect systemd, aborting installation"
        exit 1
    fi

    systemctl daemon-reload

    setcap CAP_NET_BIND_SERVICE=+eip /usr/bin/${SERVICE_NAME}

    systemctl start "${SERVICE_NAME}.service"
    systemctl enable "${SERVICE_NAME}.service"

    CUSTOM_IP=$(get_custom_ip)
    if [ -z "$CUSTOM_IP" ]; then
        echo "No 'IP' defined in ${CONFIG_FILE}. Aborting DNS configuration."
        exit 1
    fi

    CUSTOM_TLD=$(get_custom_tld)
    CUSTOM_TLD="${CUSTOM_TLD:-docker}"

    # Build routing domains from TLD (comma-separated -> space-separated ~prefixed)
    ROUTING_DOMAINS=""
    IFS=',' read -ra TLD_ARRAY <<< "$CUSTOM_TLD"
    for tld in "${TLD_ARRAY[@]}"; do
        tld=$(echo "$tld" | xargs) # trim whitespace
        if [ -n "$tld" ]; then
            ROUTING_DOMAINS="${ROUTING_DOMAINS} ~${tld}"
        fi
    done
    ROUTING_DOMAINS=$(echo "$ROUTING_DOMAINS" | xargs) # trim leading space

    if systemctl is-active systemd-resolved.service >/dev/null 2>&1; then
        echo "Detected systemd-resolved running. Extending its configuration.."

        if [ ! -d /etc/systemd/resolved.conf.d ]; then
            echo "Creating /etc/systemd/resolved.conf.d folder.."
            mkdir -p /etc/systemd/resolved.conf.d
        fi
        echo "Creating /etc/systemd/resolved.conf.d/docker-dns.conf.."
        cat <<EOF >/etc/systemd/resolved.conf.d/docker-dns.conf
[Resolve]
DNS=$CUSTOM_IP
Domains=$ROUTING_DOMAINS
EOF
        systemctl restart systemd-resolved.service
        echo "systemd-resolved extended with DNS=$CUSTOM_IP and Domains=$ROUTING_DOMAINS."
    else
        echo "systemd-resolved is not active. Updating /etc/resolv.conf.."
        grep -q "$CUSTOM_IP" /etc/resolv.conf 2>/dev/null && \
            echo "detected an entry of $CUSTOM_IP in /etc/resolv.conf, removing.." && \
            grep -v "$CUSTOM_IP" /etc/resolv.conf > /tmp/resolv.tmp && \
            cat /tmp/resolv.tmp > /etc/resolv.conf && rm -f /tmp/resolv.tmp
        # Prepend so docker-dns is queried before other nameservers
        { printf '# Generated by docker-dns\nnameserver %s\n' "$CUSTOM_IP"; cat /etc/resolv.conf; } > /tmp/resolv.tmp \
            && cat /tmp/resolv.tmp > /etc/resolv.conf && rm -f /tmp/resolv.tmp
        echo "/etc/resolv.conf updated with nameserver $CUSTOM_IP."
    fi
    ;;
*)
    echo "Usage: $0 configure"
    exit 1
    ;;
esac
